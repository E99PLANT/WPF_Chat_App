<Window x:Class="Chat_Group_System.Views.GroupSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group Settings" Height="400" Width="400"
        WindowStartupLocation="CenterOwner" Background="#F4F4F4">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Members" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

        <!-- Display list of members -->
        <ListView Grid.Row="1" x:Name="MembersListView" Margin="0,0,0,10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Width="350">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding User.DisplayName}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="Gray" Margin="10,0,10,0" VerticalAlignment="Center"/>
                        <!-- The Tag holds the UserId so we can retrieve it in the click handler -->
                        <Button Grid.Column="2" Content="Remove" Tag="{Binding UserId}" 
                                Click="RemoveMember_Click" Visibility="{Binding Path=DataContext.IsAdmin, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Use a StackPanel for adding a new user -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="EmailTextBox" Width="150" Margin="0,0,10,0" VerticalAlignment="Center" Tag="Enter Email..."/>
            <Button Content="Add Member" Click="AddMember_Click" Padding="10,5"/>
        </StackPanel>

        <!-- Leave or Disband Group -->
        <Button Grid.Row="3" x:Name="LeaveDisbandButton" Content="Leave Group" Background="IndianRed" Foreground="White" Padding="10,10" Click="LeaveDisband_Click"/>
    </Grid>
</Window>