<Window x:Class="Chat_Group_System.Views.CreateDMWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo tin nhắn 1:1" Height="200" Width="350"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI"
        Background="#F8F7F3">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="Nhập Email hoặc Tên người dùng:" FontWeight="Medium" FontSize="14" Foreground="#1A1A1A" Margin="0,0,0,10"/>
        
        <TextBox x:Name="txtSearchTerm" Grid.Row="1" Height="30" Padding="5" BorderBrush="#E8E7E3" BorderThickness="1" Background="#FFFFFF" VerticalContentAlignment="Center" Margin="0,0,0,20"/>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Width="70" Height="30" Margin="0,0,10,0" Background="#E8E8E8" BorderThickness="0" Cursor="Hand" Click="BtnCancel_Click"/>
            <Button Content="Bắt đầu" Width="80" Height="30" Background="#3B3A8B" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand" Click="BtnStart_Click"/>
        </StackPanel>
    </Grid>
</Window>