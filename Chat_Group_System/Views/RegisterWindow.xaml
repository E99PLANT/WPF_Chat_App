<Window x:Class="Chat_Group_System.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NexChat - Register" Height="600" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F8F7F3" FontFamily="Segoe UI, Inter">
    <Window.Resources>
        <!-- Re-use basic styles (Can be extracted to a global App.xaml resource later) -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F5F4F0"/>
            <Setter Property="BorderBrush" Value="#E8E7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F5F4F0"/>
            <Setter Property="BorderBrush" Value="#E8E7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B3A8B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4F4EAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#FFFFFF" CornerRadius="12" Margin="30,30" Padding="30">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🔷 Create Account" FontSize="20" FontWeight="Bold" Foreground="#3B3A8B" HorizontalAlignment="Center"/>
                <TextBlock Text="Join NexChat today" FontSize="14" Foreground="#6B6B6B" HorizontalAlignment="Center" Margin="0,5,0,25"/>

                <TextBlock Text="FULL NAME" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFullName" Margin="0,0,0,15"/>

                <TextBlock Text="EMAIL" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Margin="0,0,0,15"/>

                <TextBlock Text="PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Margin="0,0,0,15"/>

                <TextBlock Text="CONFIRM PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtConfirmPassword" Margin="0,0,0,25"/>

                <Button Content="Register" Style="{StaticResource PrimaryButtonStyle}" Click="BtnRegister_Click" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Already have an account? " Foreground="#6B6B6B" FontSize="13"/>
                    <TextBlock x:Name="btnLogin" Text="Login" Foreground="#3B3A8B" FontWeight="SemiBold" FontSize="13" Cursor="Hand" MouseDown="BtnLogin_MouseDown"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>