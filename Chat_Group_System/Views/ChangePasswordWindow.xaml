<Window x:Class="Chat_Group_System.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NexChat - Change Password" Height="550" Width="400"
        WindowStartupLocation="CenterScreen" Background="#F8F7F3" FontFamily="Segoe UI, Inter">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F5F4F0"/>
            <Setter Property="BorderBrush" Value="#E8E7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F5F4F0"/>
            <Setter Property="BorderBrush" Value="#E8E7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3B3A8B"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4F4EAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E8E7E3"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D5D4D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>    </Window.Resources>

    <Grid>
        <Border Background="#FFFFFF" CornerRadius="12" Margin="30,40" Padding="30">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <!-- Back Arrow / Header -->
                <TextBlock Text="← Back to Login" Foreground="#6B6B6B" FontSize="12" Cursor="Hand" MouseDown="BtnBackToLogin_MouseDown" Margin="0,0,0,15"/>
                
                <TextBlock Text="Change Password" FontSize="20" FontWeight="Bold" Foreground="#3B3A8B" Margin="0,0,0,5"/>
                <TextBlock Text="Enter a new password for your account" FontSize="14" Foreground="#6B6B6B" Margin="0,0,0,25" TextWrapping="Wrap"/>

                <TextBlock Text="CURRENT PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <PasswordBox x:Name="txtCurrentPassword" Padding="10,0,35,0"/>
                    <TextBox x:Name="txtVisibleCurrentPassword" Visibility="Collapsed" Padding="10,0,35,0"/>
                    <ToggleButton x:Name="btnToggleCurrentPassword" HorizontalAlignment="Right" Width="30" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnToggleCurrentPassword_Click">
                        <TextBlock Text="👁" FontSize="16" Foreground="#9A9A9A"/>
                    </ToggleButton>
                </Grid>

                <TextBlock Text="NEW PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,15">
                    <PasswordBox x:Name="txtNewPassword" Padding="10,0,35,0"/>
                    <TextBox x:Name="txtVisibleNewPassword" Visibility="Collapsed" Padding="10,0,35,0"/>
                    <ToggleButton x:Name="btnToggleNewPassword" HorizontalAlignment="Right" Width="30" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnToggleNewPassword_Click">
                        <TextBlock Text="👁" FontSize="16" Foreground="#9A9A9A"/>
                    </ToggleButton>
                </Grid>

                <TextBlock Text="CONFIRM NEW PASSWORD" FontSize="10" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,25">
                    <PasswordBox x:Name="txtConfirmNewPassword" Padding="10,0,35,0"/>
                    <TextBox x:Name="txtVisibleConfirmNewPassword" Visibility="Collapsed" Padding="10,0,35,0"/>
                    <ToggleButton x:Name="btnToggleConfirmNewPassword" HorizontalAlignment="Right" Width="30" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnToggleConfirmNewPassword_Click">
                        <TextBlock Text="👁" FontSize="16" Foreground="#9A9A9A"/>
                    </ToggleButton>
                </Grid>

                <Button Content="Update Password" Style="{StaticResource PrimaryButtonStyle}" Click="BtnUpdatePassword_Click" Margin="0,0,0,10"/>
                <Button Content="Cancel / Rollback" Style="{StaticResource SecondaryButtonStyle}" Click="BtnCancel_Click" Margin="0,0,0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>