<Window x:Class="Chat_Group_System.Views.CreateGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tạo nhóm mới" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F4F0" FontFamily="Segoe UI, Inter">
    <Border Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Tạo nhóm trò chuyện mới" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" Margin="0,0,0,15"/>
            
            <TextBlock Grid.Row="1" Text="TÊN NHÓM" FontSize="12" FontWeight="SemiBold" Foreground="#6B6B6B" Margin="0,0,0,5"/>
            <Border Grid.Row="2" Background="White" BorderBrush="#E8E7E3" BorderThickness="1" CornerRadius="6" Height="40" VerticalAlignment="Top">
                <TextBox x:Name="txtGroupName" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" FontSize="14" FocusVisualStyle="{x:Null}"/>
            </Border>
            
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Hủy" Width="80" Height="36" Background="Transparent" BorderBrush="#E8E7E3" BorderThickness="1" Foreground="#6B6B6B" Margin="0,0,10,0" Cursor="Hand" Click="BtnCancel_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="Tạo" Width="80" Height="36" Cursor="Hand" Click="BtnCreate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#3B3A8B" CornerRadius="6">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>