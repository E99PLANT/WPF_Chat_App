<Window x:Class="Chat_Group_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Chat_Group_System"
        xmlns:entities="clr-namespace:Chat_Group_System.Models.Entities"
        mc:Ignorable="d"
        Title="NexChat" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" FontFamily="Segoe UI, Inter"
        Background="#FFFFFF">
    
    <Window.Resources>        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>        <!-- Converter To Detect If Message Is Self -->
        <local:UserIdToAlignmentConverter x:Key="UserIdToAlignmentConverter" />
        <local:UserIdToBackgroundConverter x:Key="UserIdToBackgroundConverter" />
        <local:UserIdToForegroundConverter x:Key="UserIdToForegroundConverter" />
        <local:NullOrWhiteSpaceToCollapsedConverter x:Key="NullOrWhiteSpaceToCollapsedConverter" />
        <local:BytesToHumanReadableConverter x:Key="BytesToHumanReadableConverter" />
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        
        <!-- Chat Message Templates -->
        <DataTemplate x:Key="SelfMessageTemplate">
            <StackPanel Margin="0,0,0,16" HorizontalAlignment="Right">
                <Border Background="#3B3A8B" Padding="14,10" CornerRadius="16,16,4,16" MaxWidth="500" Visibility="{Binding Content, Converter={StaticResource NullOrWhiteSpaceToCollapsedConverter}}">
                    <TextBlock Text="{Binding Content}" FontSize="14" Foreground="#FFFFFF" TextWrapping="Wrap"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2" MaxWidth="500">
                                <!-- 1. IMAGE VIEW -->
                                <Border x:Name="ImgBorder" Background="#4F4EAA" CornerRadius="8" Visibility="Collapsed">
                                    <Grid>
                                        <Image x:Name="ChatImage" MaxHeight="300" Stretch="Uniform" Margin="2"/>
                                        <Button Click="BtnDownloadAttachment_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5" Width="30" Height="30" Content="📥" Background="#80000000" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Tải xuống"/>
                                    </Grid>
                                </Border>

                                <!-- 2. VIDEO VIEW -->
                                <Border x:Name="VidBorder" Background="#4F4EAA" CornerRadius="8" Visibility="Collapsed">
                                    <Grid>
                                        <MediaElement x:Name="ChatMediaElement" Loaded="ChatMediaElement_Loaded" LoadedBehavior="Manual" UnloadedBehavior="Manual" MaxHeight="300" Volume="1.0" Margin="2" ScrubbingEnabled="True" IsMuted="True"/>
                                        <Border Tag="VideoOverlay" Background="#00000000">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="▶" Foreground="White" FontSize="34" HorizontalAlignment="Center"/>
                                                <!-- <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="12" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="220" Margin="0,4,0,0"/>-->
                                            </StackPanel>
                                        </Border>
                                        <Button Tag="VideoPlayButton" Click="BtnPlayMedia_Click" Content="▶" Width="52" Height="52" Background="#00000000" Foreground="#00FFFFFF" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Phát video"/>
                                        <Button Click="BtnDownloadAttachment_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5" Width="30" Height="30" Content="📥" Background="#80000000" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Tải xuống"/>
                                    </Grid>
                                </Border>

                                <!-- 3. FILE CARD (Default) -->
                                <Border x:Name="FileBorder" Background="#3B3A8B" Padding="10" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Background="#4F4EAA" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                                            <TextBlock Text="📄" FontSize="20"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="Medium" Foreground="#FFFFFF" Margin="0,0,0,2" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SizeBytes, Converter={StaticResource BytesToHumanReadableConverter}, StringFormat={}{0}}" FontSize="11" Foreground="#FFFFFF" Opacity="0.8"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Click="BtnDownloadAttachment_Click" Content="📥" Width="30" Height="30" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Tải xuống"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="Image">
                                    <Setter TargetName="ImgBorder" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="FileBorder" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ChatImage" Property="Source" Value="{Binding FileUrl}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="Video">
                                    <Setter TargetName="VidBorder" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="FileBorder" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="ChatMediaElement" Property="Source" Value="{Binding FileUrl}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:hh:mm tt}}" FontSize="11" Foreground="#9A9A9A" Margin="0,4,14,0" HorizontalAlignment="Right"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="OtherMessageTemplate">
            <StackPanel Margin="0,0,0,16" HorizontalAlignment="Left">
                <!-- Username (only show if not a direct message, but for simplicity, we'll try to bind it and only show if it exists) -->
                <TextBlock Text="{Binding SenderName}" FontSize="12" Foreground="#6B6B6B" Margin="14,0,0,2" HorizontalAlignment="Left" Visibility="{Binding SenderName, Converter={StaticResource NullOrWhiteSpaceToCollapsedConverter}}"/>
                
                <Border Background="#F0F0F0" Padding="14,10" CornerRadius="16,16,16,4" MaxWidth="500" Visibility="{Binding Content, Converter={StaticResource NullOrWhiteSpaceToCollapsedConverter}}">
                    <TextBlock Text="{Binding Content}" FontSize="14" Foreground="#1A1A1A" TextWrapping="Wrap"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,4,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2,0,2" MaxWidth="500">
                                <!-- 1. IMAGE VIEW -->
                                <Border x:Name="ImgBorder" Background="#E0E0E0" CornerRadius="8" Visibility="Collapsed">
                                    <Grid>
                                        <Image x:Name="OtherChatImage" MaxHeight="300" Stretch="Uniform" Margin="2"/>
                                        <Button Click="BtnDownloadAttachment_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5" Width="30" Height="30" Content="📥" Background="#80000000" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Tải xuống"/>
                                    </Grid>
                                </Border>

                                <!-- 2. VIDEO VIEW -->
                                <Border x:Name="VidBorder" Background="#E0E0E0" CornerRadius="8" Visibility="Collapsed">
                                    <Grid>
                                        <MediaElement x:Name="OtherChatMediaElement" Loaded="ChatMediaElement_Loaded" LoadedBehavior="Manual" UnloadedBehavior="Manual" MaxHeight="300" Volume="1.0" Margin="2" ScrubbingEnabled="True" IsMuted="True"/>
                                        <Border Tag="VideoOverlay" Background="#00000000">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="▶" Foreground="White" FontSize="34" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding FileName}" Foreground="White" FontSize="12" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="220" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Button Tag="VideoPlayButton" Click="BtnPlayMedia_Click" Content="▶" Width="52" Height="52" Background="#00000000" Foreground="#00FFFFFF" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Phát video"/>
                                        <Button Click="BtnDownloadAttachment_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="5" Width="30" Height="30" Content="📥" Background="#80000000" Foreground="White" BorderThickness="0" Cursor="Hand" ToolTip="Tải xuống"/>
                                    </Grid>
                                </Border>

                                <!-- 3. FILE CARD (Default) -->
                                <Border x:Name="FileBorder" Background="#F0F0F0" Padding="10" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" Background="#E0E0E0" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                                            <TextBlock Text="📄" FontSize="20"/>
                                        </Border>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,5,0">
                                            <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="Medium" Foreground="#1A1A1A" Margin="0,0,0,2" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SizeBytes, Converter={StaticResource BytesToHumanReadableConverter}, StringFormat={}{0}}" FontSize="11" Foreground="#1A1A1A" Opacity="0.8"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" Click="BtnDownloadAttachment_Click" Content="📥" Width="30" Height="30" Background="Transparent" Foreground="#6B6B6B" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Tải xuống"/>
                                    </Grid>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="Image">
                                    <Setter TargetName="ImgBorder" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="FileBorder" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="OtherChatImage" Property="Source" Value="{Binding FileUrl}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Type}" Value="Video">
                                    <Setter TargetName="VidBorder" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="FileBorder" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="OtherChatMediaElement" Property="Source" Value="{Binding FileUrl}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:hh:mm tt}}" FontSize="11" Foreground="#9A9A9A" Margin="14,4,0,0" HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>

        <!-- System Message Template -->
        <DataTemplate x:Key="SystemMessageTemplate">
            <StackPanel HorizontalAlignment="Center" Margin="0,15,0,5">
                <Border Background="#E6EAF0" CornerRadius="12" Padding="12,6">
                    <TextBlock Text="{Binding Content}" FontSize="12" Foreground="#5A6D80" FontWeight="Medium" TextWrapping="Wrap"/>
                </Border>
                <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:hh:mm tt}}" FontSize="10" Foreground="#A0AAB5" Margin="0,4,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <local:MessageTemplateSelector x:Key="MessageTemplateSelector" 
            SelfMessageTemplate="{StaticResource SelfMessageTemplate}" 
            OtherMessageTemplate="{StaticResource OtherMessageTemplate}"
            SystemMessageTemplate="{StaticResource SystemMessageTemplate}"/>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="195"/>
            <!-- Chat Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================== -->
        <!-- SIDEBAR (195px fixed width)                     -->
        <!-- ============================================== -->
        <Border Grid.Column="0" Background="#F8F7F3" BorderBrush="#E8E7E3" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header / Logo -->
                    <RowDefinition Height="Auto"/> <!-- Search -->
                    <RowDefinition Height="*"/>    <!-- List -->
                </Grid.RowDefinitions>

                <!-- Logo & Add Button -->
                <Grid Grid.Row="0" Margin="16,20,16,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔷" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="NexChat" FontSize="18" FontWeight="Bold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="btnNewChat" Click="BtnNewChat_Click" Grid.Column="1" Content="👥" Margin="0,0,10,0" Background="Transparent" Foreground="#6B6B6B" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Tạo nhóm mới"/>
                    <Button x:Name="btnNewDM" Click="BtnNewDM_Click" Grid.Column="2" Content="👤" Margin="0,0,10,0" Background="Transparent" Foreground="#6B6B6B" BorderThickness="0" FontSize="16" Cursor="Hand" ToolTip="Tạo chat 1-1"/>
                    <Button x:Name="btnLogout" Click="BtnLogout_Click" Grid.Column="3" Content="🚪" Background="Transparent" Foreground="#EF4444" BorderThickness="0" FontSize="14" Cursor="Hand" ToolTip="Đăng xuất"/>
                </Grid>

                <!-- Search Box -->
                <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E8E7E3" BorderThickness="1" CornerRadius="6" Margin="16,0,16,16" Padding="10,0" Height="36">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" Foreground="#9A9A9A" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBox x:Name="txtSearch" Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Foreground="#9A9A9A" Background="Transparent" BorderThickness="0" FontSize="13" VerticalAlignment="Center" FocusVisualStyle="{x:Null}" GotFocus="TxtSearch_GotFocus" LostFocus="TxtSearch_LostFocus" TextChanged="TxtSearch_TextChanged"/>
                    </Grid>
                </Border>

                <!-- Conversations List (Scrollable) -->
                <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,0">
                        <!-- GROUP CHATS SECTION -->
                        <TextBlock Text="CHATS" FontSize="10" FontWeight="SemiBold" Foreground="#9A9A9A" Margin="6,10,0,8"/>
                        
                        <ListBox x:Name="ConvList" ItemsSource="{Binding FilteredConversations}" SelectedItem="{Binding SelectedConversation, Mode=TwoWay}" 
                                 Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="ConvList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#3B3A8B"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter Property="Background" Value="#EAE6DF"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Avatar with Online Dot -->
                                        <Grid Grid.Column="0">
                                            <Ellipse Width="36" Height="36" Fill="#E8E8E8"/>
                                            <TextBlock Text="{Binding Name[0]}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#3B3A8B" FontSize="14" FontWeight="SemiBold"/>
                                            
                                            <!-- Online Dot -->
                                            <Ellipse Width="12" Height="12" Fill="#22C55E" Stroke="#F8F7F3" StrokeThickness="2"
                                                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2"
                                                     Visibility="{Binding IsOnline, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        </Grid>
                                        
                                        <!-- Info Area -->
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#3D3D3D"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding UnreadCount}" Value="0">
                                                                    <Setter Property="FontWeight" Value="Medium" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                
                                                <!-- Unread counter -->
                                                <Border Grid.Column="1" Background="#EF4444" CornerRadius="10" MinWidth="20" Height="20" Padding="0" Margin="4,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding UnreadCount}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding UnreadCount}" Foreground="#FFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            
                                            <TextBlock Text="{Binding LastMessagePreview}" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#9A9A9A"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="#EEEDF8"/>
                                                            </DataTrigger>
                                                            <!-- Null fallback done via TargetNullValue in real life but we use triggers -->
                                                            <DataTrigger Binding="{Binding LastMessagePreview}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="Chưa có tin nhắn"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ============================================== -->
        <!-- CHAT AREA                                       -->
        <!-- ============================================== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/> <!-- Chat Header -->
                <RowDefinition Height="*"/>  <!-- Message List -->
                <RowDefinition Height="Auto"/> <!-- Input Area -->
            </Grid.RowDefinitions>

            <!-- 1) Chat Header -->
            <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#E8E7E3" BorderThickness="0,0,0,1" Padding="20,0" DataContext="{Binding SelectedConversation}">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="40" Height="40" Fill="#4F4EAA"/>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="#1A1A1A"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding TypeText}" FontSize="12" Foreground="#6B6B6B" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Header Icons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="🔔" Background="Transparent" BorderThickness="0" Foreground="#6B6B6B" FontSize="16" Margin="0,0,15,0" Cursor="Hand"/>
                        <Button Content="⋯" Background="Transparent" BorderThickness="0" Foreground="#6B6B6B" FontSize="16" Cursor="Hand" Click="BtnGroupSettings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2) Message Bubble Area -->
            <Grid Grid.Row="1" Background="#FFFFFF">
                <ScrollViewer x:Name="MessageScrollViewer" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="MessageList" ItemsSource="{Binding CurrentMessages}" Margin="25,25,25,45" VerticalAlignment="Bottom" ItemTemplateSelector="{StaticResource MessageTemplateSelector}">
                    </ItemsControl>
                </ScrollViewer>
                
                <!-- Typing Indicator overlay at bottom of scroll viewer -->
                <StackPanel VerticalAlignment="Bottom" Margin="25,0,0,15" Visibility="{Binding IsTyping, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Ellipse Width="32" Height="32" Fill="#E8E8E8" Margin="0,0,8,0" VerticalAlignment="Bottom"/>
                        <Border Background="#F0F0F0" Padding="14,10" CornerRadius="16,16,16,4" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Resources>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <TranslateTransform Y="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </StackPanel.Resources>
                                <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="#9A9A9A" Margin="0,0,4,0"/>
                                <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="#9A9A9A" Margin="0,0,4,0"/>
                                <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="#9A9A9A"/>
                                <StackPanel.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard x:Name="TypingStoryboard">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-4" AutoReverse="True" Duration="0:0:0.3"/>
                                                <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-4" AutoReverse="True" Duration="0:0:0.3" BeginTime="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="0" To="-4" AutoReverse="True" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </StackPanel.Triggers>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding TypingMessage}" Foreground="#9A9A9A" FontSize="11" Margin="40,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- 3) Input Area -->
            <Border Grid.Row="2" Background="#F5F4F0" BorderBrush="#E8E7E3" BorderThickness="0,1,0,0" Padding="16,12">
                <Grid>
                    <!-- User is Member: Show Input Area -->
                    <Grid Visibility="{Binding CanSendMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Tools -->
                            <ColumnDefinition Width="*"/>    <!-- TextBox -->
                            <ColumnDefinition Width="Auto"/> <!-- Send -->
                        </Grid.ColumnDefinitions>

                        <!-- Tools -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
                            <Button x:Name="btnEmoji" Content="😊" Background="Transparent" BorderThickness="0" Foreground="#6B6B6B" FontSize="18" Margin="0,0,8,0" Cursor="Hand" Click="BtnEmoji_Click"/>
                            <Popup x:Name="EmojiPickerPopup" PlacementTarget="{Binding ElementName=btnEmoji}" Placement="Top" StaysOpen="False" VerticalOffset="-5">
                                <Border Background="#FFFFFF" BorderBrush="#E8E7E3" BorderThickness="1" CornerRadius="8" Padding="8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.1" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <UniformGrid Columns="5" Rows="2">
                                        <Button Content="😀" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="😂" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="😍" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="👍" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="🙌" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="❤️" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="🔥" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="🎉" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="🤔" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                        <Button Content="😎" FontSize="20" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnEmojiPick_Click"/>
                                    </UniformGrid>
                                </Border>
                            </Popup>

                            <Button x:Name="btnSelectFile" Content="📎" Background="Transparent" BorderThickness="0" Foreground="#6B6B6B" FontSize="18" Margin="0,0,8,0" Cursor="Hand" Click="BtnSelectFile_Click"/>
                            <Button x:Name="btnSelectImage" Content="🖼" Background="Transparent" BorderThickness="0" Foreground="#6B6B6B" FontSize="18" Cursor="Hand" Click="BtnSelectImage_Click"/>
                        </StackPanel>

                        <!-- Text input -->
                        <TextBox x:Name="txtInputMessage" Grid.Column="1" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" Foreground="#9A9A9A" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" FocusVisualStyle="{x:Null}" KeyDown="TxtInputMessage_KeyDown" GotFocus="TxtInputMessage_GotFocus" LostFocus="TxtInputMessage_LostFocus"/>

                        <!-- Send Button -->
                        <Button x:Name="btnSend" Click="BtnSend_Click" Grid.Column="2" MinWidth="75" Height="36" Cursor="Hand" Margin="15,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#3B3A8B" CornerRadius="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,0">
                                            <TextBlock Text="Gửi" Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="➤" Foreground="#FFFFFF" FontSize="10" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- User is NOT Member: Cannot Send Message -->
                    <Grid Visibility="{Binding CanSendMessage, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <TextBlock Text="Bạn không thể nhắn vào trong group này" Foreground="#9A9A9A" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" FontStyle="Italic"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
